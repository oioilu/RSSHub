{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "hono",
    "outputDirectory": "src",
    "rewrites": [
        {
            "source": "/favicon.ico",
            "destination": "/favicon.png"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=60, s-maxage=60"
                }
            ]
        }
    ],
    "github": {
        "silent": true
    }
}
